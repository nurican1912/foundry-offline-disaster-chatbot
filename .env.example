# Örnek ortam değişkenleri. Bu dosyayı ".env" olarak kopyalayıp değerleri
# ihtiyacına göre değiştir. .env commit'lenmez; .env.example commit'lenir.
# Not: Bu projede gizli anahtar YOK (Foundry Local tamamen lokal çalışır).
# Buradaki değerler yalnızca ayarlanabilir parametrelerdir; hepsinin
# app/config.py içinde makul varsayılanları var, .env opsiyoneldir.

APP_NAME=emergency_rag
CHAT_MODEL_ALIAS=qwen2.5-1.5b
EMBEDDING_MODEL_ALIAS=qwen3-embedding-0.6b
TOP_K=3
SIMILARITY_THRESHOLD=0.5
DB_PATH=data/emergency.db
DOCS_DIR=docs/raw
